# SymPhony Insight backend LLM settings template.
# Copy this file to backend/.env.local and fill in real values locally.
# Never commit backend/.env.local or any file containing a real API key.

# Provider mode:
# - mock: use deterministic local mock responses
# - disabled: reject LLM generation requests
# - real: call the configured LLM endpoint
SYMPHONY_AI_PROVIDER_MODE=mock

# LLM endpoint and authentication.
# Example endpoint shapes:
# - https://api.example.com/v1/chat/completions
# - https://your-gateway.example.com/v1/responses
SYMPHONY_LLM_ENDPOINT=https://api.example.com/v1/chat/completions
SYMPHONY_LLM_API_KEY=replace_with_your_api_key

# Model/provider options.
SYMPHONY_LLM_MODEL=replace_with_model_name
SYMPHONY_LLM_TIMEOUT_SECONDS=45
SYMPHONY_LLM_TEMPERATURE=0.2
SYMPHONY_LLM_MAX_OUTPUT_TOKENS=1600

# Optional headers. Leave blank if your provider does not require them.
SYMPHONY_LLM_ORG_ID=
SYMPHONY_LLM_PROJECT_ID=

# Prompt and safety trace metadata.
SYMPHONY_LLM_PROMPT_VERSION=report-draft-v1-2026-06
SYMPHONY_LLM_SAFETY_VERSION=report-safety-v1-2026-06

# Local development API settings.
SYMPHONY_BACKEND_HOST=127.0.0.1
SYMPHONY_BACKEND_PORT=8000
SYMPHONY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend can later use these in its own .env.local when backend mode exists.
VITE_API_MODE=backend
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
