{
  "name": "symphony-insight-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite --host 127.0.0.1 --port 5173",
    "dev:frontend:backend": "VITE_API_MODE=backend VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1 vite --host 127.0.0.1 --port 5173",
    "dev:backend": "cd backend && python3 -m app.server",
    "build:server": "VITE_API_MODE=backend VITE_API_BASE_URL=/api/v1 npm run build",
    "start:server": "cd backend && python3 -m app.server",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "test:backend": "cd backend && python3 -m unittest discover -s tests",
    "test:all": "npm test && npm run build && npm run test:backend"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^2.15.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
